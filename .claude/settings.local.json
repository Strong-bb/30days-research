{
  "permissions": {
    "allow": [
      "Skill(last30days:last30days-skill)",
      "WebSearch",
      "Bash(last30days --help)",
      "Bash(npx last30days:*)",
      "Bash(chmod 600:*)",
      "Skill(last30days)",
      "WebFetch(domain:www.verdent.ai)",
      "WebFetch(domain:www.latent.space)",
      "WebFetch(domain:www.reddit.com)",
      "Bash(bash:*)",
      "Bash(python:*)",
      "Bash(chmod +x:*)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:kirill-markin.com)",
      "WebFetch(domain:www.deployhq.com)",
      "Bash(curl -sL \"https://raw.githubusercontent.com/openai/codex/main/AGENTS.md\")",
      "Bash(curl -sL \"https://api.github.com/repos/openai/codex/contents\")",
      "Bash(python3 -c \"import sys,json; [print\\(f['name'], f['type']\\) for f in json.loads\\(sys.stdin.read\\(\\)\\)]\")",
      "Bash(curl -sL \"https://raw.githubusercontent.com/openai/codex/main/README.md\")",
      "Bash(curl -sL \"https://api.github.com/repos/openai/codex\")",
      "Bash(python3 -c \"import sys,json; d=json.loads\\(sys.stdin.read\\(\\)\\); print\\(d.get\\('description','N/A'\\)\\); print\\('Full name:', d.get\\('full_name','N/A'\\)\\); print\\('Default branch:', d.get\\('default_branch','N/A'\\)\\)\")",
      "Bash(getnote auth:*)",
      "Bash(getnote kbs:*)",
      "Bash(getnote save:*)",
      "WebFetch(domain:www.biji.com)",
      "Bash(curl -s \"https://www.biji.com/openapi\")",
      "Bash(gh api:*)",
      "Bash(getnote kb:*)",
      "Bash(getnote notes:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/context-guard.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
